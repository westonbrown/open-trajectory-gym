# Open Trajectory Gym Configuration
# Copy to .env and customize for your setup

# ==============================================================================
# LLM CONFIGURATION
# ==============================================================================

# Model provider (ollama, openai, anthropic, etc.)
TRAJGYM_PROVIDER=ollama

# LLM model for agent reasoning
TRAJGYM_MODEL=ollama/qwen3:8b

# Ollama server configuration
OLLAMA_HOST=http://localhost:11434

# ==============================================================================
# OUTPUT CONFIGURATION
# ==============================================================================

TRAJGYM_OUTPUT_DIR=./outputs

# ==============================================================================
# OPTIONAL: CLOUD PROVIDERS (uncomment if using)
# ==============================================================================

# OpenAI
# OPENAI_API_KEY=your_key
# TRAJGYM_MODEL=openai/gpt-4o

# Anthropic (via LiteLLM)
# ANTHROPIC_API_KEY=your_key
# TRAJGYM_MODEL=anthropic/claude-sonnet-4-20250514

# OpenRouter
# OPENROUTER_API_KEY=your_key
# TRAJGYM_MODEL=openrouter/openai/gpt-oss-120b

# ==============================================================================
# TRAINING (Optional)
# ==============================================================================

# Weights & Biases for training metrics
# WANDB_API_KEY=your_key
# WANDB_PROJECT=open-trajectory-gym

# HuggingFace token for private models (optional)
# HF_TOKEN=your_token

# ==============================================================================
# DATA COLLECTION (Optional)
# ==============================================================================

# BoxPwnr agent settings for CyBench data collection
# See: docs/data-collection.md

# BOXPWNR_MODEL=gpt-4o
# BOXPWNR_MAX_COST=10.0
# BOXPWNR_OUTPUT_DIR=./targets
